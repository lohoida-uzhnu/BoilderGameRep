<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BoulderGame.MainWindow"
        Title="MainMenu"
        Width="800" Height="600"
        MinWidth="450" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.MenuBtn">
            <Setter Property="Width" Value="350"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*, 2*, Auto">
        
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="DODGE BOULDER"
                       FontSize="40"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Spacing="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
            <Button Content="Start Game"
                    Click="StartGameBut_Click"
                    Classes="MenuBtn"/>
            
            <Button Content="Statistic" 
                    Click="StatButton_Click"
                    Classes="MenuBtn"/>
            
            <Button Content="Setting"
                    Click="SettingBut_Click"
                    Classes="MenuBtn"/>
            
            <Button Content="Exit"
                    Click="ExitButton_Click"
                    Classes="MenuBtn"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="10"
                    HorizontalAlignment="Left">
            <TextBlock Text="Version: Beta 1.0"/>
        </StackPanel>

        <ContentControl Name="MainContent" IsHitTestVisible="False"/>
    </Grid>
</Window>