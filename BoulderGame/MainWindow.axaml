<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BoulderGame.MainWindow"
        Title="MainMenu"
        Width="800" Height="600"
        MinWidth="450" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*, 2*, Auto">
        
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="DODGE BOULDER" Classes="Header"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Spacing="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
            <Button 
                    Content="Start Game" 
                    Click="StartGameBut_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="Statistic" 
                    Click="StatButton_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="Setting" 
                    Click="SettingBut_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="Exit" 
                    Click="ExitButton_Click" 
                    Classes="MenuBtn"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="10"
                    HorizontalAlignment="Left">
            <TextBlock Text="Version: Beta 1.0" Foreground="Gray"/>
        </StackPanel>

        <ContentControl Name="MainContent" IsHitTestVisible="False"/>
    </Grid>
</Window>