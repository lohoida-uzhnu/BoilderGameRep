<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:BoulderGame"
             x:DataType="local:RegisterViewModel"
             x:Class="BoulderGame.RegisterPage">

    <Border Background="{DynamicResource SystemAltHighColor}" 
            Width="400" 
            CornerRadius="8" 
            Padding="40" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center">
        
        <StackPanel Spacing="15">
            <TextBlock Text="{DynamicResource SignUpTitle}" 
                       FontSize="28" 
                       Foreground="{DynamicResource SystemBaseHighColor}"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource LoginField}"/>
                <TextBox Text="{Binding Login, Mode=TwoWay}"
                         PlaceholderText="Enter login"
                         Classes="Auth"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource PasswordField}"/>
                <TextBox Text="{Binding Password, Mode=TwoWay}"
                         PasswordChar="*" 
                         PlaceholderText="Enter password"
                         Classes="Auth"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource ConfPass}"/>
                <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay}"
                         PlaceholderText="Confirm password"
                         PasswordChar="*" 
                         Classes="Auth"/>
            </StackPanel>

            <TextBlock Name="ErrorText" 
                       Foreground="Red" 
                       FontSize="12" 
                       IsVisible="False" 
                       HorizontalAlignment="Center"/>
            
            <Button Content="{DynamicResource SignUpButton}" 
                    Click="SignUp_Click"
                    Background="#087B9C" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Height="45" 
                    CornerRadius="4"
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    Margin="0,10,0,15"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource LoginLink}"/>
                <TextBlock Text="{DynamicResource LoginLinkAction}" 
                           Foreground="#087B9C" 
                           Cursor="Hand" 
                           PointerPressed="GoToSignIn_Click">
                    <TextBlock.Styles>
                        <Style Selector="TextBlock:pointerover">
                            <Setter Property="TextDecorations" Value="Underline"/>
                        </Style>
                    </TextBlock.Styles>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>