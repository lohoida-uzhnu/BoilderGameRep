<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:BoulderGame"
             x:DataType="local:LoginViewModel"
             x:Class="BoulderGame.LoginPage">

    <Border Background="{DynamicResource SystemAltHighColor}" 
            Width="400" 
            CornerRadius="8" 
            Padding="40" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"
            BoxShadow="0 4 15 0 #40000000"> <StackPanel Spacing="15">

            <TextBlock Text="{DynamicResource LoginTitle}" 
                       FontSize="28" 
                       Foreground="{DynamicResource SystemBaseHighColor}"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource LoginField}"/>
                <TextBox Text="{Binding Login, Mode=TwoWay}"
                         PlaceholderText="Enter login" 
                         Classes="Auth"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource PasswordField}" />
                <TextBox Text="{Binding Password, Mode=TwoWay}"
                         Name="PassBox"
                         PlaceholderText="Enter password" 
                         PasswordChar="*" 
                         Classes="Auth"/>
            </StackPanel>

            <CheckBox Name="ShowPassCheck" 
                      Content="{StaticResource ShowPass}" 
                      Foreground="{DynamicResource SystemBaseHighColor}"

                      Margin="0,-5,0,5" 
                      IsCheckedChanged="ShowPass_Changed"/>

            <TextBlock Name="ErrorText" 
                       Foreground="Red" 
                       FontSize="12" 
                       IsVisible="False" 
                       HorizontalAlignment="Center"/>

            <Button Content="{DynamicResource SignInButton}" 
                    Click="SignIn_Click"
                    Background="#087B9C" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Height="45" 
                    CornerRadius="4"
                    HorizontalAlignment="Stretch" 
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    Margin="0,10,0,20"/>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource RegisterLink}"/>
                    <TextBlock Text="{DynamicResource RegisterLinkAction}" 
                               Foreground="#087B9C" 
                               Cursor="Hand" 
                               PointerPressed="GoToSignUp_Click">
                        <TextBlock.Styles>
                            <Style Selector="TextBlock:pointerover">
                                <Setter Property="TextDecorations" 
                                        Value="Underline"/>
                            </Style>
                        </TextBlock.Styles>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
    </Border>
</UserControl>